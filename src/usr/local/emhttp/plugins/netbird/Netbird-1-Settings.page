<?php
try {
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "{$docroot}/plugins/netbird/include/common.php";

$plugin = 'netbird';
$cfg    = function_exists('parse_plugin_cfg') ? parse_plugin_cfg($plugin) : [];

// Global daemon options live in netbird.cfg.
$enabled       = $cfg['ENABLE_NETBIRD']   ?? '0';
$enableSsh     = $cfg['ENABLE_SSH']       ?? '0';
$manageDns     = $cfg['MANAGE_DNS']       ?? '1';
$logLevel      = $cfg['LOG_LEVEL']        ?? 'info';

$enableCfg     = strtolower(trim((string) $enabled));
$serviceEnabled = !in_array($enableCfg, ['0', 'false'], true);
$daemonReady   = $serviceEnabled && Netbird\daemonRunning() && file_exists('/var/run/netbird.sock');
$profiles      = $daemonReady ? Netbird\listProfiles() : [];
if (!$profiles) {
    $profiles = Netbird\savedProfiles();
}
$activeProf = '';
foreach ($profiles as $profile) {
    if ($profile['active']) {
        $activeProf = $profile['name'];
        break;
    }
}

// Which profile's credentials is the form editing? ?nbprofile= wins, then the
// active profile, then "default" (NetBird's built-in profile).
$editProf = (string) ($_GET['nbprofile'] ?? '');
if (!Netbird\validProfileName($editProf)) {
    $editProf = '';
}
if ($editProf === '') {
    $editProf = $activeProf;
    if ($editProf === '' && $profiles) {
        $editProf = $profiles[0]['name'];
        foreach ($profiles as $profile) {
            if ($profile['name'] === 'default') {
                $editProf = 'default';
                break;
            }
        }
    }
    if ($editProf === '') {
        $editProf = 'default';
    }
}

// Credentials are stored per profile (profiles/<name>.cfg), not globally.
$creds         = Netbird\readProfileCfg($editProf);
$mgmtUrl       = $creds['MANAGEMENT_URL'];
$setupKey      = $creds['SETUP_KEY'];
$hostname      = $creds['HOSTNAME'];
$preSharedKey  = $creds['PRESHARED_KEY'];
?>

<style>
    .nb-profile-bar {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 12px; border: 1px solid var(--panel-bdr);
        border-radius: 4px; margin-bottom: 14px;
    }
    .nb-profile-bar label { margin: 0; font-weight: 600; }
    .nb-profile-bar select, .nb-profile-bar input[type=text] { margin: 0; min-width: 180px; }
    .nb-profile-bar input[type=button] { margin: 0; }
    .nb-profile-empty { color: var(--text-muted, #888); }
</style>

<div class="nb-profile-bar">
    <label for="nb-profile-select">_(Profile)_:</label>
    <?php if ($profiles): ?>
        <select id="nb-profile-select" onchange="nbViewProfile(this.value)">
            <?php foreach ($profiles as $p): ?>
                <option value="<?=htmlspecialchars($p['name'])?>" <?=$p['name'] === $editProf ? 'selected' : ''?>>
                    <?=htmlspecialchars($p['name'])?><?=$p['active'] ? ' (active)' : ''?>
                </option>
            <?php endforeach; ?>
        </select>
        <?php if ($daemonReady): ?>
            <input type="button" value="_(Switch)_" onclick="nbProfile('select', $('#nb-profile-select').val())">
            <input type="button" value="_(Delete)_" onclick="nbProfileDelete()">
        <?php endif; ?>
    <?php else: ?>
        <span class="nb-profile-empty">No saved profiles yet — editing <code><?=htmlspecialchars($editProf)?></code>.</span>
    <?php endif; ?>
    <?php if ($daemonReady): ?>
        &nbsp;&nbsp;
        <input type="text" id="nb-profile-new" placeholder="new-profile-name" maxlength="32">
        <input type="button" value="_(+ Add)_" onclick="nbProfileAdd()">
    <?php else: ?>
        <span class="nb-profile-empty">Profile controls are available while NetBird is running.</span>
    <?php endif; ?>
</div>

<blockquote class="inline_help">
NetBird supports multiple profiles so you can keep separate identities (e.g., a personal NetBird Cloud account and a self-hosted tenant) on the same host. Switching profiles re-runs <code>netbird up</code> against the new profile using the credentials you fill in below.
</blockquote>

<form markdown="1" id="nb-settings-form" onsubmit="return false">
<input type="hidden" id="nb-edit-profile" value="<?=htmlspecialchars($editProf)?>">

_(Enable NetBird)_:
: <select name="ENABLE_NETBIRD">
  <?=mk_option($enabled, "1", _("Yes"))?>
  <?=mk_option($enabled, "0", _("No"))?>
  </select>

<blockquote class="inline_help">
Start the NetBird daemon automatically when the array starts. Fresh installations
remain stopped until NetBird is enabled and configured. Disabling stops the
service on the next apply.
</blockquote>

_(Editing Profile)_:
: <code><?=htmlspecialchars($editProf)?></code><?php if ($editProf === $activeProf): ?> _(active)_<?php endif; ?>

<blockquote class="inline_help">
The credentials below belong to the <b><?=htmlspecialchars($editProf)?></b> profile only. Pick a different profile in the bar above to edit its credentials. Clicking <b>Apply</b> saves these credentials to this profile, selects it, and reconnects — it does not touch your other profiles.
</blockquote>

_(Management URL)_:
: <input type="url" name="MANAGEMENT_URL" value="<?=htmlspecialchars($mgmtUrl)?>" placeholder="https://api.netbird.io (default)" autocomplete="off" data-1p-ignore data-lpignore="true" data-form-type="other">

<blockquote class="inline_help">
Leave blank to use the public NetBird cloud. Set this to your self-hosted NetBird management server URL.
</blockquote>

_(Setup Key)_:
: <input type="password" name="SETUP_KEY" value="<?=htmlspecialchars($setupKey)?>" autocomplete="off">

<blockquote class="inline_help">
Pre-authentication setup key from your NetBird dashboard. Required the first time you register a profile, and after changing the management URL or hostname (which re-registers the peer). Reconnecting an already-registered profile does not need it. This plugin always registers with a setup key; interactive SSO login is not used.
</blockquote>

_(Hostname)_:
: <input type="text" name="HOSTNAME" value="<?=htmlspecialchars($hostname)?>" placeholder="<?=gethostname()?>">

<blockquote class="inline_help">
Override the hostname this peer registers as. Defaults to the Unraid server's hostname.
</blockquote>

_(Pre-shared Key)_:
: <input type="password" name="PRESHARED_KEY" value="<?=htmlspecialchars($preSharedKey)?>" autocomplete="off">

<blockquote class="inline_help">
Optional WireGuard pre-shared key. Only required if your NetBird network is configured to use one.
</blockquote>

_(Log Level)_:
: <select name="LOG_LEVEL">
  <?=mk_option($logLevel, "panic", _("Panic"))?>
  <?=mk_option($logLevel, "fatal", _("Fatal"))?>
  <?=mk_option($logLevel, "error", _("Error"))?>
  <?=mk_option($logLevel, "warn",  _("Warn"))?>
  <?=mk_option($logLevel, "info",  _("Info"))?>
  <?=mk_option($logLevel, "debug", _("Debug"))?>
  <?=mk_option($logLevel, "trace", _("Trace"))?>
  </select>

<blockquote class="inline_help">
NetBird daemon log verbosity. Written to <code>/var/log/netbird.log</code>.
</blockquote>

_(Manage DNS)_:
: <select name="MANAGE_DNS">
  <?=mk_option($manageDns, "1", _("Yes"))?>
  <?=mk_option($manageDns, "0", _("No"))?>
  </select>

<blockquote class="inline_help">
When enabled (default), NetBird runs its own DNS resolver and rewrites <code>/etc/resolv.conf</code> so it can resolve NetBird domains and any nameservers your network defines. If this leaves the host unable to resolve regular internet names (see <a href="https://github.com/netbirdio/netbird-unraid/issues/2" target="_blank" rel="noopener noreferrer">issue #2</a>), set this to <b>No</b> to pass <code>--disable-dns</code> — NetBird then leaves the host's DNS untouched and uses your existing <code>/etc/resolv.conf</code>. The cleaner fix is usually to configure a nameserver group in the NetBird dashboard instead. Changing this reconnects NetBird to take effect.
</blockquote>

_(Enable NetBird SSH)_:
: <select name="ENABLE_SSH">
  <?=mk_option($enableSsh, "0", _("No"))?>
  <?=mk_option($enableSsh, "1", _("Yes"))?>
  </select>

<blockquote class="inline_help">
Runs NetBird's built-in SSH server so other peers can SSH into this Unraid host as <code>root</code> using NetBird identity (no separate SSH keys to manage). <b>Security:</b> this grants root SSH to any peer your NetBird access controls permit, so leave it disabled unless you need it. You must also enable SSH for this peer and create an access control policy in the NetBird dashboard — see <a href="https://docs.netbird.io/manage/peers/ssh#step-2-create-access-control-policy" target="_blank" rel="noopener noreferrer">the NetBird SSH guide</a>. Changing this reconnects NetBird to take effect.
</blockquote>

: <input type="button" value="_(Apply)_" onclick="nbSaveSettings()"><input type="button" value="_(Done)_" onclick="done()">
</form>

<script>
var nbCsrfToken = <?= json_encode((@parse_ini_file('/var/local/emhttp/var.ini') ?: [])['csrf_token'] ?? '') ?>;

// Where to send the browser after an action completes. Defaults to a plain
// reload; pass a profile name to land on that profile's credentials.
function nbReloadTo(profile) {
    if (profile) {
        location.href = location.pathname + '?nbprofile=' + encodeURIComponent(profile);
    } else {
        location.reload();
    }
}

function nbProfile(action, name, extra) {
    var data = { action: 'profile-' + action, name: name, csrf_token: nbCsrfToken };
    if (extra) { $.extend(data, extra); }
    $.post('/plugins/netbird/include/action.php', data, function(resp){
        if (resp && resp.message) {
            swal({ title: resp.title || 'NetBird', text: resp.message, type: resp.type || 'info' });
        }
        setTimeout(function(){ nbReloadTo(resp && resp.profile); }, 1200);
    }, 'json').fail(function(xhr){
        swal({ title: 'NetBird error', text: xhr.responseText || 'Request failed', type: 'error' });
    });
}
function nbProfileAdd() {
    var name = ($('#nb-profile-new').val() || '').trim();
    if (!name) { swal({ title: 'NetBird', text: 'Enter a profile name first.', type: 'warning' }); return; }
    if (!/^[A-Za-z0-9_.-]{1,32}$/.test(name)) {
        swal({ title: 'NetBird', text: 'Profile names: letters, digits, dot, dash, underscore (max 32).', type: 'warning' }); return;
    }
    nbProfile('add', name);
}
// View a profile's stored credentials without changing the active profile.
function nbViewProfile(name) {
    if (name) { nbReloadTo(name); }
}
// Save the global options + the edited profile's credentials, then apply.
function nbSaveSettings() {
    var profile = $('#nb-edit-profile').val();
    var form = document.getElementById('nb-settings-form');
    var enableNetBird = $('select[name=ENABLE_NETBIRD]', form).val();
    // A setup key is required only when registering: a profile that has no key
    // stored yet (initial setup). Reconnecting an already-registered profile
    // doesn't need one. (A management-URL/hostname change also re-registers; the
    // server enforces that case and returns a clear error if the key is missing.)
    var nbRequireKey = <?= empty($setupKey) ? 'true' : 'false' ?>;
    if (enableNetBird === '1' && nbRequireKey && !($('input[name=SETUP_KEY]', form).val() || '').trim()) {
        swal({ title: 'Setup key required',
               text: 'Enter a setup key from your NetBird dashboard to register this profile. Interactive SSO login is not supported.',
               type: 'warning' });
        return;
    }
    var data = {
        action:         'save',
        name:           profile,
        ENABLE_NETBIRD: enableNetBird,
        ENABLE_SSH:     $('select[name=ENABLE_SSH]', form).val(),
        MANAGE_DNS:     $('select[name=MANAGE_DNS]', form).val(),
        LOG_LEVEL:      $('select[name=LOG_LEVEL]', form).val(),
        MANAGEMENT_URL: $('input[name=MANAGEMENT_URL]', form).val(),
        SETUP_KEY:      $('input[name=SETUP_KEY]', form).val(),
        HOSTNAME:       $('input[name=HOSTNAME]', form).val(),
        PRESHARED_KEY:  $('input[name=PRESHARED_KEY]', form).val(),
        csrf_token:     nbCsrfToken
    };
    $.post('/plugins/netbird/include/action.php', data, function(resp){
        if (resp && resp.pending) {
            // apply.sh runs in the background; poll for its result so we can
            // report success/failure instead of blindly reloading.
            swal({ title: 'Applying…', text: resp.message || 'Applying NetBird settings…',
                   type: 'info', showConfirmButton: false });
            nbPollApply(profile, resp.since || 0, 48);
        } else if (resp && resp.message) {
            swal({ title: resp.title || 'NetBird', text: resp.message, type: resp.type || 'info' });
            setTimeout(function(){ nbReloadTo(resp && resp.profile); }, 1200);
        } else {
            setTimeout(function(){ nbReloadTo(profile); }, 1200);
        }
    }, 'json').fail(function(xhr){
        swal({ title: 'NetBird error', text: xhr.responseText || 'Request failed', type: 'error' });
    });
}
// Poll apply-status until apply.sh reports a result for this profile newer than
// `since` (ok === true/false), or we run out of tries (~96s), then reload.
function nbPollApply(profile, since, triesLeft) {
    $.post('/plugins/netbird/include/action.php', { action: 'apply-status', csrf_token: nbCsrfToken }, function(res){
        var done = res && res.profile === profile && res.ts >= since && (res.ok === true || res.ok === false);
        if (done) {
            swal(res.ok
                ? { title: 'Settings applied', text: res.message || 'Applied.', type: 'success' }
                : { title: 'Apply failed', text: res.message || 'Could not apply settings.', type: 'error' });
            setTimeout(function(){ nbReloadTo(profile); }, 1500);
            return;
        }
        if (triesLeft <= 0) {
            swal({ title: 'Still applying', text: 'NetBird is still working in the background. Reloading…', type: 'info' });
            setTimeout(function(){ nbReloadTo(profile); }, 1500);
            return;
        }
        setTimeout(function(){ nbPollApply(profile, since, triesLeft - 1); }, 2000);
    }, 'json').fail(function(){
        if (triesLeft <= 0) { nbReloadTo(profile); return; }
        setTimeout(function(){ nbPollApply(profile, since, triesLeft - 1); }, 2000);
    });
}
function nbProfileDelete() {
    var name = $('#nb-profile-select').val();
    if (!name) { return; }
    swal({
        title: 'Delete profile "' + name + '"?',
        text: 'This removes the profile and its stored credentials on this host. Cannot be undone.',
        type: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Delete',
        cancelButtonText: 'Cancel'
    }, function(confirmed){
        if (confirmed) { nbProfile('remove', name); }
    });
}
</script>
<?php
} catch (\Throwable $e) {
    echo "<div style='background:#fee;padding:12px;border:1px solid #c00;border-radius:4px;'>"
       . "<b>NetBird plugin error</b><pre>" . htmlspecialchars($e->getMessage() . "\n@ " . $e->getFile() . ':' . $e->getLine()) . "</pre></div>";
}
?>
